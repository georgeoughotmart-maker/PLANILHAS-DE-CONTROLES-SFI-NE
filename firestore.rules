rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "georgeoughotmart@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function isValidRow(data) {
      return data.id is string &&
             data.neNumber is string &&
             data.neNumber.size() <= 100 &&
             (!('obDate' in data) || data.obDate is string) &&
             (!('obValidityDays' in data) || data.obValidityDays is string) &&
             (!('value' in data) || data.value is string) &&
             (!('reDate' in data) || data.reDate is string) &&
             (!('prestacaoDate' in data) || data.prestacaoDate is string) &&
             (!('vencimentoDate' in data) || data.vencimentoDate is string) &&
             (!('lancadoPlanilha' in data) || data.lancadoPlanilha is string) &&
             (!('isConfirmed' in data) || data.isConfirmed is bool);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /spreadsheet_rows/{rowId} {
      // Explicitly allow get and list to be public
      allow get, list: if true;
      
      // Allow authenticated users to write
      allow create: if isAuthenticated() && isValidRow(request.resource.data);
      allow update: if isAuthenticated() && isValidRow(request.resource.data);
      allow delete: if isAuthenticated() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
